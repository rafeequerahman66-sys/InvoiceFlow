# ── Database ─────────────────────────────────────────────────────────────────
# LOCAL DEV (default schema = SQLite, prisma/schema.prisma): fast, offline.
DATABASE_URL="file:./dev.db"
#
# PRODUCTION (Postgres/Supabase): copy prisma/schema.postgres.prisma over
# prisma/schema.prisma, then use the connection string below.
# Supabase: Connect -> Session pooler (IPv4). URL-encode special chars in the
# password (@ -> %40). Direct host (db.<ref>.supabase.co) is IPv6-only.
# DATABASE_URL="postgresql://postgres.<ref>:<PASSWORD>@aws-1-<region>.pooler.supabase.com:5432/postgres?connect_timeout=30&pool_timeout=30"

# ── Auth (optional) ──────────────────────────────────────────────────────────
# App runs in personal/no-login mode by default (middleware is a pass-through).
# To re-enable Google sign-in, restore the auth() middleware and set these.
AUTH_SECRET="run: npx auth secret"
AUTH_GOOGLE_ID="your-google-oauth-client-id"
AUTH_GOOGLE_SECRET="your-google-oauth-client-secret"
ALLOWED_EMAILS="rafeequerahman66@gmail.com"

# ── @supabase/server SDK (server-side; separate from DATABASE_URL/Prisma) ────
# From Supabase dashboard → Connect. NEVER commit SUPABASE_SECRET_KEY.
SUPABASE_URL="https://<project-ref>.supabase.co"
SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."
SUPABASE_SECRET_KEY="sb_secret_..."
SUPABASE_JWKS_URL="https://<project-ref>.supabase.co/auth/v1/.well-known/jwks.json"

# ── Integrations (optional; default to safe mocks when unset) ────────────────
# EMAIL_PROVIDER=resend        RESEND_API_KEY=...
# PAYMENT_PROVIDER=razorpay    RAZORPAY_KEY_ID=...  RAZORPAY_KEY_SECRET=...
# STORAGE_DRIVER=s3            AWS_ACCESS_KEY_ID=... (or CLOUDINARY_URL=...)
# AI_PROVIDER=claude           ANTHROPIC_API_KEY=...
