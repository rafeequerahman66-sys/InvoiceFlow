// Prisma schema for InvoiceFlow — multi-tenant SaaS (PRODUCTION = Postgres/Supabase).
// `rhel-openssl-3.0.x` is the Vercel (AWS Lambda) runtime target.
// Mirror of prisma/schema.prisma (SQLite dev) with real enums + @db types + Json.
generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum ItemKind {
  SERVICE
  PRODUCT
}

enum DiscountType {
  PERCENT
  FLAT
}

enum SupplyType {
  INTRA_STATE
  INTER_STATE
  EXPORT_LUT
  EXPORT_WITH_TAX
}

enum InvoiceStatus {
  DRAFT
  SENT
  PARTIALLY_PAID
  PAID
  OVERDUE
  CANCELLED
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
  CONVERTED
}

enum PaymentMethod {
  BANK_TRANSFER
  UPI
  RAZORPAY
  CRYPTO
  OTHER
}

enum DocType {
  INVOICE
  QUOTE
}

/// A tenant. Holds the business profile that used to be the BusinessProfile singleton.
model Organization {
  id             String   @id @default(cuid())
  name           String
  slug           String   @unique
  legalName      String?
  gstin          String?
  stateCode      String   @default("32")
  address        String?
  email          String?
  phone          String?
  lutNumber      String?
  defaultSacCode String?  @default("998361")
  bankName       String?
  bankAccount    String?
  ifsc           String?
  swift          String?
  logoUrl        String?
  invoicePrefix  String   @default("INV")
  quotePrefix    String   @default("QT")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  memberships     Membership[]
  clients         Client[]
  catalogItems    CatalogItem[]
  invoices        Invoice[]
  quotes          Quotation[]
  recurring       RecurringInvoice[]
  numberSequences NumberSequence[]
  logs            ActivityLog[]
}

model User {
  id           String       @id @default(cuid())
  email        String       @unique
  name         String?
  passwordHash String?
  memberships  Membership[]
  invoices     Invoice[]
  quotes       Quotation[]
  recurring    RecurringInvoice[]
  logs         ActivityLog[]
  createdAt    DateTime     @default(now())
}

model Membership {
  id        String       @id @default(cuid())
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  orgId     String
  role      Role         @default(MEMBER)
  createdAt DateTime     @default(now())

  @@unique([userId, orgId])
  @@index([orgId])
}

model Client {
  id              String       @id @default(cuid())
  org             Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  orgId           String
  name            String
  company         String?
  email           String?
  phone           String?
  billingAddress  String?
  country         String       @default("IN")
  stateCode       String?
  gstin           String?
  defaultCurrency String       @default("INR")
  notes           String?
  invoices        Invoice[]
  quotes          Quotation[]
  recurring       RecurringInvoice[]
  archived        Boolean      @default(false)
  createdAt       DateTime     @default(now())

  @@index([orgId])
  @@index([orgId, company])
}

model CatalogItem {
  id          String       @id @default(cuid())
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  orgId       String
  name        String
  description String?
  kind        ItemKind     @default(SERVICE)
  sacCode     String?
  defaultRate Decimal      @db.Decimal(12, 2)
  defaultTax  Decimal      @default(18) @db.Decimal(5, 2)
  archived    Boolean      @default(false)
  createdAt   DateTime     @default(now())

  @@index([orgId])
}

/// Gapless sequential numbering, one counter per org per financial year per doc type.
model NumberSequence {
  id         String       @id @default(cuid())
  org        Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  orgId      String
  docType    DocType
  fyLabel    String
  lastNumber Int          @default(0)

  @@unique([orgId, docType, fyLabel])
}

model Invoice {
  id             String        @id @default(cuid())
  org            Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  orgId          String
  number         String
  fyLabel        String
  client         Client        @relation(fields: [clientId], references: [id])
  clientId       String
  status         InvoiceStatus @default(DRAFT)
  issueDate      DateTime
  dueDate        DateTime
  currency       String        @default("INR")
  fxRateToInr    Decimal       @default(1) @db.Decimal(12, 4)
  supplyType     SupplyType
  placeOfSupply  String?
  subtotal       Decimal       @db.Decimal(14, 2)
  discountType   DiscountType  @default(PERCENT)
  discountValue  Decimal       @default(0) @db.Decimal(14, 2)
  taxableValue   Decimal       @db.Decimal(14, 2)
  cgst           Decimal       @default(0) @db.Decimal(14, 2)
  sgst           Decimal       @default(0) @db.Decimal(14, 2)
  igst           Decimal       @default(0) @db.Decimal(14, 2)
  total          Decimal       @db.Decimal(14, 2)
  totalInr       Decimal       @db.Decimal(14, 2)
  notes          String?
  terms          String?
  lutDeclaration Boolean       @default(false)
  pdfUrl         String?
  items          InvoiceItem[]
  payments       Payment[]
  createdBy      User          @relation(fields: [createdById], references: [id])
  createdById    String
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@unique([orgId, number])
  @@index([orgId, status])
  @@index([orgId, issueDate])
}

model InvoiceItem {
  id           String   @id @default(cuid())
  invoice      Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  invoiceId    String
  name         String
  description  String?
  sacCode      String?
  qty          Decimal  @default(1) @db.Decimal(10, 2)
  unit         String?  @default("nos")
  rate         Decimal  @db.Decimal(12, 2)
  taxRate      Decimal  @default(18) @db.Decimal(5, 2)
  lineSubtotal Decimal  @db.Decimal(14, 2)
  lineTax      Decimal  @db.Decimal(14, 2)
  lineTotal    Decimal  @db.Decimal(14, 2)
}

model Quotation {
  id                 String       @id @default(cuid())
  org                Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  orgId              String
  number             String
  fyLabel            String
  client             Client       @relation(fields: [clientId], references: [id])
  clientId           String
  status             QuoteStatus  @default(DRAFT)
  issueDate          DateTime
  validTill          DateTime
  currency           String       @default("INR")
  supplyType         SupplyType
  subtotal           Decimal      @db.Decimal(14, 2)
  discountType       DiscountType @default(PERCENT)
  discountValue      Decimal      @default(0) @db.Decimal(14, 2)
  taxableValue       Decimal      @db.Decimal(14, 2)
  totalTax           Decimal      @db.Decimal(14, 2)
  total              Decimal      @db.Decimal(14, 2)
  notes              String?
  terms              String?
  convertedInvoiceId String?
  items              QuoteItem[]
  createdBy          User         @relation(fields: [createdById], references: [id])
  createdById        String
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  @@unique([orgId, number])
  @@index([orgId, status])
}

model QuoteItem {
  id          String    @id @default(cuid())
  quote       Quotation @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  quoteId     String
  name        String
  description String?
  sacCode     String?
  qty         Decimal   @default(1) @db.Decimal(10, 2)
  rate        Decimal   @db.Decimal(12, 2)
  taxRate     Decimal   @default(18) @db.Decimal(5, 2)
  lineTotal   Decimal   @db.Decimal(14, 2)
}

model Payment {
  id        String        @id @default(cuid())
  invoice   Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  invoiceId String
  amount    Decimal       @db.Decimal(14, 2)
  currency  String        @default("INR")
  method    PaymentMethod @default(BANK_TRANSFER)
  reference String?
  paidAt    DateTime
  notes     String?
  createdAt DateTime      @default(now())

  @@index([invoiceId])
}

model ActivityLog {
  id         String        @id @default(cuid())
  org        Organization? @relation(fields: [orgId], references: [id], onDelete: Cascade)
  orgId      String?
  actor      User?         @relation(fields: [actorId], references: [id])
  actorId    String?
  action     String
  entityType String
  entityId   String
  meta       Json?
  createdAt  DateTime      @default(now())

  @@index([orgId])
  @@index([entityType, entityId])
}

/// Template that auto-generates invoices on a cadence (retainers).
model RecurringInvoice {
  id            String          @id @default(cuid())
  org           Organization    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  orgId         String
  title         String?
  client        Client          @relation(fields: [clientId], references: [id])
  clientId      String
  cadence       String          @default("MONTHLY")
  nextRunDate   DateTime
  active        Boolean         @default(true)
  currency      String          @default("INR")
  supplyType    SupplyType
  discountType  DiscountType    @default(PERCENT)
  discountValue Decimal         @default(0) @db.Decimal(14, 2)
  notes         String?
  terms         String?
  items         RecurringItem[]
  createdBy     User            @relation(fields: [createdById], references: [id])
  createdById   String
  lastRunAt     DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([orgId, active, nextRunDate])
}

model RecurringItem {
  id          String           @id @default(cuid())
  recurring   RecurringInvoice @relation(fields: [recurringId], references: [id], onDelete: Cascade)
  recurringId String
  name        String
  description String?
  sacCode     String?
  qty         Decimal          @default(1) @db.Decimal(10, 2)
  rate        Decimal          @db.Decimal(12, 2)
  taxRate     Decimal          @default(18) @db.Decimal(5, 2)
}
