// Prisma schema for InvoiceFlow — multi-tenant SaaS (LOCAL DEV = SQLite).
//
// Row-level multi-tenancy: every tenant table carries orgId and is scoped per
// Organization. SQLite has no native enums/@db/Json, so enum-ish fields are
// String (allowed values in comments). Production schema (Postgres, with real
// enums + @db + Json) is prisma/schema.postgres.prisma — keep them in lockstep.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Role: OWNER|ADMIN|MEMBER|VIEWER · ItemKind: SERVICE|PRODUCT
// DiscountType: PERCENT|FLAT · SupplyType: INTRA_STATE|INTER_STATE|EXPORT_LUT|EXPORT_WITH_TAX
// InvoiceStatus: DRAFT|SENT|PARTIALLY_PAID|PAID|OVERDUE|CANCELLED
// QuoteStatus: DRAFT|SENT|ACCEPTED|REJECTED|EXPIRED|CONVERTED
// PaymentMethod: BANK_TRANSFER|UPI|RAZORPAY|CRYPTO|OTHER · DocType: INVOICE|QUOTE
// Cadence: WEEKLY|MONTHLY|QUARTERLY|YEARLY

/// A tenant. Holds the business profile that used to be the BusinessProfile singleton.
model Organization {
  id             String   @id @default(cuid())
  name           String
  slug           String   @unique
  legalName      String?
  gstin          String?
  stateCode      String   @default("32")
  address        String?
  email          String?
  phone          String?
  lutNumber      String?
  defaultSacCode String?  @default("998361")
  bankName       String?
  bankAccount    String?
  ifsc           String?
  swift          String?
  logoUrl        String?
  invoicePrefix  String   @default("INV")
  quotePrefix    String   @default("QT")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  memberships     Membership[]
  clients         Client[]
  catalogItems    CatalogItem[]
  invoices        Invoice[]
  quotes          Quotation[]
  recurring       RecurringInvoice[]
  numberSequences NumberSequence[]
  logs            ActivityLog[]
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  name         String?
  passwordHash String?
  memberships  Membership[]
  invoices     Invoice[]
  quotes       Quotation[]
  recurring    RecurringInvoice[]
  logs         ActivityLog[]
  createdAt    DateTime      @default(now())
}

/// Links a user to an org with a role.
model Membership {
  id        String       @id @default(cuid())
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  orgId     String
  role      String       @default("MEMBER")
  createdAt DateTime     @default(now())

  @@unique([userId, orgId])
  @@index([orgId])
}

model Client {
  id              String       @id @default(cuid())
  org             Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  orgId           String
  name            String
  company         String?
  email           String?
  phone           String?
  billingAddress  String?
  country         String       @default("IN")
  stateCode       String?
  gstin           String?
  defaultCurrency String       @default("INR")
  notes           String?
  invoices        Invoice[]
  quotes          Quotation[]
  recurring       RecurringInvoice[]
  archived        Boolean      @default(false)
  createdAt       DateTime     @default(now())

  @@index([orgId])
  @@index([orgId, company])
}

model CatalogItem {
  id          String       @id @default(cuid())
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  orgId       String
  name        String
  description String?
  kind        String       @default("SERVICE")
  sacCode     String?
  defaultRate Decimal
  defaultTax  Decimal      @default(18)
  archived    Boolean      @default(false)
  createdAt   DateTime     @default(now())

  @@index([orgId])
}

/// Gapless sequential numbering, one counter per org per FY per doc type.
model NumberSequence {
  id         String       @id @default(cuid())
  org        Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  orgId      String
  docType    String
  fyLabel    String
  lastNumber Int          @default(0)

  @@unique([orgId, docType, fyLabel])
}

model Invoice {
  id             String        @id @default(cuid())
  org            Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  orgId          String
  number         String
  fyLabel        String
  client         Client        @relation(fields: [clientId], references: [id])
  clientId       String
  status         String        @default("DRAFT")
  issueDate      DateTime
  dueDate        DateTime
  currency       String        @default("INR")
  fxRateToInr    Decimal       @default(1)
  supplyType     String
  placeOfSupply  String?
  subtotal       Decimal
  discountType   String        @default("PERCENT")
  discountValue  Decimal       @default(0)
  taxableValue   Decimal
  cgst           Decimal       @default(0)
  sgst           Decimal       @default(0)
  igst           Decimal       @default(0)
  total          Decimal
  totalInr       Decimal
  notes          String?
  terms          String?
  lutDeclaration Boolean       @default(false)
  pdfUrl         String?
  items          InvoiceItem[]
  payments       Payment[]
  createdBy      User          @relation(fields: [createdById], references: [id])
  createdById    String
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@unique([orgId, number])
  @@index([orgId, status])
  @@index([orgId, issueDate])
}

model InvoiceItem {
  id           String   @id @default(cuid())
  invoice      Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  invoiceId    String
  name         String
  description  String?
  sacCode      String?
  qty          Decimal  @default(1)
  unit         String?  @default("nos")
  rate         Decimal
  taxRate      Decimal  @default(18)
  lineSubtotal Decimal
  lineTax      Decimal
  lineTotal    Decimal
}

model Quotation {
  id                 String       @id @default(cuid())
  org                Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  orgId              String
  number             String
  fyLabel            String
  client             Client       @relation(fields: [clientId], references: [id])
  clientId           String
  status             String       @default("DRAFT")
  issueDate          DateTime
  validTill          DateTime
  currency           String       @default("INR")
  supplyType         String
  subtotal           Decimal
  discountType       String       @default("PERCENT")
  discountValue      Decimal      @default(0)
  taxableValue       Decimal
  totalTax           Decimal
  total              Decimal
  notes              String?
  terms              String?
  convertedInvoiceId String?
  items              QuoteItem[]
  createdBy          User         @relation(fields: [createdById], references: [id])
  createdById        String
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  @@unique([orgId, number])
  @@index([orgId, status])
}

model QuoteItem {
  id          String    @id @default(cuid())
  quote       Quotation @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  quoteId     String
  name        String
  description String?
  sacCode     String?
  qty         Decimal   @default(1)
  rate        Decimal
  taxRate     Decimal   @default(18)
  lineTotal   Decimal
}

model Payment {
  id        String   @id @default(cuid())
  invoice   Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  invoiceId String
  amount    Decimal
  currency  String   @default("INR")
  method    String   @default("BANK_TRANSFER")
  reference String?
  paidAt    DateTime
  notes     String?
  createdAt DateTime @default(now())

  @@index([invoiceId])
}

model ActivityLog {
  id         String        @id @default(cuid())
  org        Organization? @relation(fields: [orgId], references: [id], onDelete: Cascade)
  orgId      String?
  actor      User?         @relation(fields: [actorId], references: [id])
  actorId    String?
  action     String
  entityType String
  entityId   String
  meta       String?
  createdAt  DateTime      @default(now())

  @@index([orgId])
  @@index([entityType, entityId])
}

/// Template that auto-generates invoices on a cadence (retainers).
model RecurringInvoice {
  id            String          @id @default(cuid())
  org           Organization    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  orgId         String
  title         String?
  client        Client          @relation(fields: [clientId], references: [id])
  clientId      String
  cadence       String          @default("MONTHLY")
  nextRunDate   DateTime
  active        Boolean         @default(true)
  currency      String          @default("INR")
  supplyType    String
  discountType  String          @default("PERCENT")
  discountValue Decimal         @default(0)
  notes         String?
  terms         String?
  items         RecurringItem[]
  createdBy     User            @relation(fields: [createdById], references: [id])
  createdById   String
  lastRunAt     DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([orgId, active, nextRunDate])
}

model RecurringItem {
  id          String           @id @default(cuid())
  recurring   RecurringInvoice @relation(fields: [recurringId], references: [id], onDelete: Cascade)
  recurringId String
  name        String
  description String?
  sacCode     String?
  qty         Decimal          @default(1)
  rate        Decimal
  taxRate     Decimal          @default(18)
}
