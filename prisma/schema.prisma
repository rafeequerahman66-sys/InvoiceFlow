// Prisma schema for InvoiceFlow — Rin Media internal billing tool.
//
// LOCAL DEV uses SQLite (file-based, fast, offline) because this machine's
// network path to Supabase is slow/flaky. The canonical PRODUCTION schema
// (PostgreSQL, with real enums + @db types + Json) is kept in
// prisma/schema.postgres.prisma. To use Supabase: copy that over this file,
// set DATABASE_URL to the Supabase URL, and run `prisma migrate deploy`.
// SQLite has no native enums / @db types / Json, so enum fields are String
// (allowed values noted below) and ActivityLog.meta is JSON-encoded text.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// String-enum values:
// Role: OWNER|MEMBER · ItemKind: SERVICE|PRODUCT · DiscountType: PERCENT|FLAT
// SupplyType: INTRA_STATE|INTER_STATE|EXPORT_LUT|EXPORT_WITH_TAX
// InvoiceStatus: DRAFT|SENT|PARTIALLY_PAID|PAID|OVERDUE|CANCELLED
// QuoteStatus: DRAFT|SENT|ACCEPTED|REJECTED|EXPIRED|CONVERTED
// PaymentMethod: BANK_TRANSFER|UPI|RAZORPAY|CRYPTO|OTHER · DocType: INVOICE|QUOTE

/// Singleton: Rin Media's own details. Seed exactly one row (id = "rinmedia").
model BusinessProfile {
  id             String   @id @default("rinmedia")
  legalName      String   @default("Crew Catalyst Innovations Private Limited")
  brandName      String   @default("Rin Media")
  gstin          String   @default("32AANCC1730B1ZB")
  stateCode      String   @default("32")
  address        String
  email          String
  phone          String?
  lutNumber      String?
  defaultSacCode String?  @default("998361")
  bankName       String?
  bankAccount    String?
  ifsc           String?
  swift          String?
  logoUrl        String?
  invoicePrefix  String   @default("INV")
  quotePrefix    String   @default("QT")
  updatedAt      DateTime @updatedAt
}

model User {
  id        String        @id @default(cuid())
  email     String        @unique
  name      String?
  role      String        @default("MEMBER")
  invoices  Invoice[]
  quotes    Quotation[]
  recurring RecurringInvoice[]
  logs      ActivityLog[]
  createdAt DateTime      @default(now())
}

model Client {
  id              String      @id @default(cuid())
  name            String
  company         String?
  email           String?
  phone           String?
  billingAddress  String?
  country         String      @default("IN")
  stateCode       String?
  gstin           String?
  defaultCurrency String      @default("INR")
  notes           String?
  invoices        Invoice[]
  quotes          Quotation[]
  recurring       RecurringInvoice[]
  archived        Boolean     @default(false)
  createdAt       DateTime    @default(now())

  @@index([company])
}

model CatalogItem {
  id          String   @id @default(cuid())
  name        String
  description String?
  kind        String   @default("SERVICE")
  sacCode     String?
  defaultRate Decimal
  defaultTax  Decimal  @default(18)
  archived    Boolean  @default(false)
  createdAt   DateTime @default(now())
}

/// Gapless sequential numbering, one counter per financial year per doc type.
model NumberSequence {
  id         String @id @default(cuid())
  docType    String
  fyLabel    String
  lastNumber Int    @default(0)

  @@unique([docType, fyLabel])
}

model Invoice {
  id             String        @id @default(cuid())
  number         String        @unique
  fyLabel        String
  client         Client        @relation(fields: [clientId], references: [id])
  clientId       String
  status         String        @default("DRAFT")
  issueDate      DateTime
  dueDate        DateTime
  currency       String        @default("INR")
  fxRateToInr    Decimal       @default(1)
  supplyType     String
  placeOfSupply  String?
  subtotal       Decimal
  discountType   String        @default("PERCENT")
  discountValue  Decimal       @default(0)
  taxableValue   Decimal
  cgst           Decimal       @default(0)
  sgst           Decimal       @default(0)
  igst           Decimal       @default(0)
  total          Decimal
  totalInr       Decimal
  notes          String?
  terms          String?
  lutDeclaration Boolean       @default(false)
  pdfUrl         String?
  items          InvoiceItem[]
  payments       Payment[]
  createdBy      User          @relation(fields: [createdById], references: [id])
  createdById    String
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([clientId, status])
  @@index([issueDate])
}

model InvoiceItem {
  id           String   @id @default(cuid())
  invoice      Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  invoiceId    String
  name         String
  description  String?
  sacCode      String?
  qty          Decimal  @default(1)
  unit         String?  @default("nos")
  rate         Decimal
  taxRate      Decimal  @default(18)
  lineSubtotal Decimal
  lineTax      Decimal
  lineTotal    Decimal
}

model Quotation {
  id                 String      @id @default(cuid())
  number             String      @unique
  fyLabel            String
  client             Client      @relation(fields: [clientId], references: [id])
  clientId           String
  status             String      @default("DRAFT")
  issueDate          DateTime
  validTill          DateTime
  currency           String      @default("INR")
  supplyType         String
  subtotal           Decimal
  discountType       String      @default("PERCENT")
  discountValue      Decimal     @default(0)
  taxableValue       Decimal
  totalTax           Decimal
  total              Decimal
  notes              String?
  terms              String?
  convertedInvoiceId String?
  items              QuoteItem[]
  createdBy          User        @relation(fields: [createdById], references: [id])
  createdById        String
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  @@index([clientId, status])
}

model QuoteItem {
  id          String    @id @default(cuid())
  quote       Quotation @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  quoteId     String
  name        String
  description String?
  sacCode     String?
  qty         Decimal   @default(1)
  rate        Decimal
  taxRate     Decimal   @default(18)
  lineTotal   Decimal
}

model Payment {
  id        String   @id @default(cuid())
  invoice   Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  invoiceId String
  amount    Decimal
  currency  String   @default("INR")
  method    String   @default("BANK_TRANSFER")
  reference String?
  paidAt    DateTime
  notes     String?
  createdAt DateTime @default(now())

  @@index([invoiceId])
}

model ActivityLog {
  id         String   @id @default(cuid())
  actor      User?    @relation(fields: [actorId], references: [id])
  actorId    String?
  action     String
  entityType String
  entityId   String
  meta       String?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
}

/// Template that auto-generates invoices on a cadence (retainers).
model RecurringInvoice {
  id            String          @id @default(cuid())
  title         String?
  client        Client          @relation(fields: [clientId], references: [id])
  clientId      String
  cadence       String          @default("MONTHLY") // WEEKLY|MONTHLY|QUARTERLY|YEARLY
  nextRunDate   DateTime
  active        Boolean         @default(true)
  currency      String          @default("INR")
  supplyType    String
  discountType  String          @default("PERCENT")
  discountValue Decimal         @default(0)
  notes         String?
  terms         String?
  items         RecurringItem[]
  createdBy     User            @relation(fields: [createdById], references: [id])
  createdById   String
  lastRunAt     DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([active, nextRunDate])
}

model RecurringItem {
  id          String           @id @default(cuid())
  recurring   RecurringInvoice @relation(fields: [recurringId], references: [id], onDelete: Cascade)
  recurringId String
  name        String
  description String?
  sacCode     String?
  qty         Decimal          @default(1)
  rate        Decimal
  taxRate     Decimal          @default(18)
}
